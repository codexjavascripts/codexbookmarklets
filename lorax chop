javascript:(function(){const style=document.createElement('style');style.innerHTML=`@keyframes pureChop {0%{transform:translate(-50%,-50%) scale(1) rotate(0deg);transform-origin:bottom left;}20%{transform:translate(-50%,-50%) scale(2.5) rotate(-45deg);transform-origin:bottom left;}45%{transform:translate(-50%,-50%) scale(2.5) rotate(60deg);transform-origin:bottom left;}100%{transform:translate(-50%,-50%) scale(0) rotate(90deg);}} .clean-axe {position:absolute;font-size:70px;z-index:999999;pointer-events:none;transform:translate(-50%,-50%);}`;document.head.appendChild(style);document.addEventListener('click',function(e){if(e.target.tagName==='IMG'||e.target.closest('picture')){e.preventDefault();const img=e.target;const a=document.createElement('div');a.className='clean-axe';a.innerText='🪓';a.style.left=e.pageX+'px';a.style.top=e.pageY+'px';a.style.animation='pureChop 0.6s cubic-bezier(0.18, 0.89, 0.32, 1.28) forwards';document.body.appendChild(a);setTimeout(()=>{img.style.transition='transform 0.5s ease-in, opacity 0.4s';img.style.transformOrigin='center';img.style.transform='rotate(-15deg) translateY(300px) scale(0.1)';img.style.opacity='0';setTimeout(()=>{img.remove();a.remove();},500);},250);}},{once:false});})();
